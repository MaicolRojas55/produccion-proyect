# Configuración de Base de Datos
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=produccion_db

# Configuración JWT
JWT_SECRET_KEY=change-this-secret-value-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Configuración OTP
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10

# Configuración Email SMTP (Gmail)
# 1. Habilita autenticación de 2 factores en tu cuenta Gmail
# 2. Genera una "contraseña de aplicación" en:
#    https://myaccount.google.com/apppasswords
# 3. Usa esa contraseña (16 caracteres) abajo

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=abcd-efgh-ijkl-mnop
SMTP_FROM_EMAIL=tu-email@gmail.com
SMTP_FROM_NAME=CONIITI Conference