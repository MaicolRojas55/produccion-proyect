# ============== CONFIGURACIÓN API ==============

# URL base del backend API (rutas bajo /auth, /users, etc. → prefijo /api en gateway)
#
# Recomendado con Vite (mismo origen + proxy en vite.config.ts):
#   VITE_API_URL=/api
#   API_PROXY_TARGET=http://127.0.0.1:8080
#
# Desarrollo local (uvicorn directo, sin prefijo /api):
#   VITE_API_URL=http://localhost:8000
#
# Producción detrás de un reverse proxy que sirva /api:
#   VITE_API_URL=/api
VITE_API_URL=/api

# Solo para `npm run dev` / preview: destino del proxy /api (Compose interno: http://gateway:80)
# API_PROXY_TARGET=http://127.0.0.1:8080

# ============== ENTORNO ==============

# Entorno de la aplicación (development | staging | production)
VITE_ENVIRONMENT=development

# Timeout para peticiones HTTP en milisegundos
VITE_API_TIMEOUT=30000

# ============== OPCIONES AVANZADAS ==============

# Logging nivel (debug | info | warn | error)
# VITE_LOG_LEVEL=info

# Modo offline (true para pruebas sin backend)
# VITE_OFFLINE_MODE=false