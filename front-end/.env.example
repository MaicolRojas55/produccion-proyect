# ============== CONFIGURACIÓN API ==============

# URL base del backend API
# Desarrollo: http://localhost:8000
# Producción: https://api.ejemplo.com
VITE_API_URL=http://localhost:8000

# ============== ENTORNO ==============

# Entorno de la aplicación (development | staging | production)
VITE_ENVIRONMENT=development

# Timeout para peticiones HTTP en milisegundos
VITE_API_TIMEOUT=30000

# ============== OPCIONES AVANZADAS ==============

# Logging nivel (debug | info | warn | error)
# VITE_LOG_LEVEL=info

# Modo offline (true para pruebas sin backend)
# VITE_OFFLINE_MODE=false